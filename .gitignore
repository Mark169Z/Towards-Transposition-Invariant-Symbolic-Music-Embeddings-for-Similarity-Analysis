```gitignore
# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]

# ==========================================================
# Node.js
# ==========================================================
node_modules/

# ==========================================================
# IDE
# ==========================================================
.vscode/
.idea/

# ==========================================================
# OS
# ==========================================================
.DS_Store
Thumbs.db

# ==========================================================
# Generated outputs
# ==========================================================

# Generated embeddings
embeddings/*
!embeddings/.gitkeep

# Generated edgelists
edgelist_file/*
!edgelist_file/.gitkeep

# Generated plots
plot/plots_embeddings/
plot/similarity_results/

# GraphSAGE debug outputs
graphsage/debug_tables/

# ==========================================================
# Logs
# ==========================================================
*.log
```
